# Optional overrides. The app can also read USERNAME/PASSWORD/base URL from agents.md.
WORKORDER_USERNAME=your_username
WORKORDER_PASSWORD=your_password
WORKORDER_BASE_URL=https://workorder.bosssoft.com.cn/api/v1

# Fill these with the exact Apifox paths if the built-in candidates fail.
# Multiple paths are comma-separated.
WORKORDER_CUSTOMER_PATHS=/companies,/customers,/customer/list
WORKORDER_CONTACT_PATHS=/users,/contacts,/contact/list,/contacters,/contacter/list
WORKORDER_TICKET_PATHS=/tickets,/ticket/list,/workorders,/workorder/list

# The API uses HTTP Basic Auth. List endpoints currently work with GET.
WORKORDER_HTTP_METHODS=GET,POST

WORKORDER_TICKET_SINCE=2025-01-01
WORKORDER_SAMPLE_SIZE=10
WORKORDER_PAGE_SIZE=100
WORKORDER_MAX_PAGES=200

# Local MySQL target. Put the real password in your local .env, not in Git.
WORKORDER_MYSQL_HOST=127.0.0.1
WORKORDER_MYSQL_PORT=3306
WORKORDER_MYSQL_USER=root
WORKORDER_MYSQL_PASSWORD=your_mysql_password
WORKORDER_MYSQL_DATABASE=work_order
